<%- include("../partials/nav.ejs") %>

<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <section class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <h1 class="fw-bold mb-2">List Your Equipment</h1>
                        <p class="text-muted">Add your gear to the marketplace and start earning.</p>
                    </div>

                    <form action="/equipment" method="POST" enctype="multipart/form-data">

                        <div class="mb-3">
                            <label class="form-label fw-bold" for="title">Equipment Name</label>
                            <input class="form-control form-control-lg bg-light border-0" type="text" name="title" id="title" placeholder="e.g., Canon R5" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold" for="category">Category</label>
                            <select class="form-select form-select-lg bg-light border-0" name="category" id="category" required>
                                <option value="" disabled selected>Select a category</option>
                                <option value="Cameras">Cameras</option>
                                <option value="Lenses">Lenses</option>
                                <option value="Lighting">Lighting</option>
                                <option value="Audio Gear">Audio Gear</option>
                                <option value="Production Accessories">Production Accessories</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold" for="dailyPrice">Price per Day</label>
                            <div class="input-group input-group-lg shadow-sm">
                                <input class="form-control bg-light border-0" type="number" name="dailyPrice" id="dailyPrice" min="0" required>
                                <span class="input-group-text bg-danger text-white border-0">BHD</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold" for="description">Description</label>
                            <textarea class="form-control bg-light border-0" name="description" id="description" rows="4" placeholder="Brief details about the gear..." required></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold" for="image">Equipment Image</label>
                            <input class="form-control bg-light border-0" type="file" name="image" id="image" accept="image/jpeg,image/png,image/webp" required>
                        </div>

                        <button class="btn btn-danger btn-lg w-100 fw-bold mt-2" type="submit">Add Equipment</button>
                    </form>
                    
                </div>
            </section>

        </div>
    </div>
</main>

<%- include("../partials/footer.ejs") %>