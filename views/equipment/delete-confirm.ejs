<%- include("../partials/nav.ejs") %>

<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6 text-center">
            
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">                
                <i class="bi bi-exclamation-circle text-danger display-1 mb-4 d-block"></i>
                
                <h1 class="fw-bold mb-3">Are you sure?</h1>
                <p class="text-muted fs-5 mb-4">
                    You are about to delete <strong class="text-dark"><%= foundEquipment.title %></strong>.<br>
                    This action cannot be undone.
                </p>
                
                <div class="d-flex justify-content-center gap-3 mt-3">
                    
                    <a href="/equipment/<%= foundEquipment._id %>" class="btn btn-dark btn-lg px-4 fw-bold">
                        Cancel
                    </a>

                    <form action="/equipment/<%= foundEquipment._id %>?_method=DELETE" method="POST" class="m-0">
                        <button class="btn btn-danger btn-lg px-4 fw-bold" type="submit">
                            Yes, Delete
                        </button>
                    </form>
                    
                </div>

            </div>
            
        </div>
    </div>
</main>

<%- include("../partials/footer.ejs") %>