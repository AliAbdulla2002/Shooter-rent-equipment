<%- include("../partials/nav.ejs") %>

<main class="container my-5">
    
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
        <i class="bi bi-heart-fill text-danger fs-2 me-3"></i>
        <h1 class="fw-bold mb-0">My Favorite Equipment</h1>
    </div>

    <div class="row g-4">
        <% if (favoriteEquipments.length > 0) { %>
            <% favoriteEquipments.forEach(equipment => { %>
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                        
                        <div class="ratio ratio-4x3 bg-light">
                            <img src="<%= equipment.image.url %>" class="object-fit-cover" alt="<%= equipment.title %>">
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title fw-bold mb-0 text-dark pe-2">
                                    <%= equipment.title %>
                                </h5>
                                <span class="badge bg-danger fs-6 ms-2 text-nowrap"><%= equipment.dailyPrice %> BHD / day</span>
                            </div>

                            <p class="text-muted small mb-4">
                                <i class="bi bi-tag-fill me-1 text-danger"></i><%= equipment.category %>
                            </p>

                            <a href="/equipment/<%= equipment._id %>"
                                class="btn btn-outline-dark mt-auto w-100 fw-bold">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>

        <% } else { %>
            <div class="col-12 text-center py-5">
                <div class="py-5">
                    <i class="bi bi-heartbreak display-1 text-muted mb-3 d-block"></i>
                    <h3 class="fw-bold mb-3">You haven't favorited any equipment yet.</h3>
                    <p class="text-muted mb-4">Explore our marketplace and save the gear you love!</p>
                    <a href="/equipment" class="btn btn-danger btn-lg px-5 fw-bold">Browse Equipment</a>
                </div>
            </div>
        <% } %>
    </div>

</main>

<%- include("../partials/footer.ejs") %>