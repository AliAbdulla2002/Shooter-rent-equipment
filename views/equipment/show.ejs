<%- include("../partials/nav.ejs") %>

<main class="container my-5">
    
    <div class="row g-5">
        <div class="col-md-6">
            <div class="ratio ratio-4x3 bg-light rounded-4 shadow-sm overflow-hidden">
                <img src="<%= foundEquipment.image.url %>" class="object-fit-cover w-100 h-100" alt="<%= foundEquipment.title %>" />
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-center">
            
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="fw-bold mb-0 text-dark"><%= foundEquipment.title %></h1>
                
                <div class="favorites-section">
                    <% if (userHasFavorited) { %>
                        <form action="/equipment/<%= foundEquipment._id %>/favorited-by/<%= user._id %>?_method=DELETE" method="POST" class="m-0">
                            <button class="btn btn-danger rounded-circle p-2 lh-1 shadow-sm" type="submit" title="Remove from Favorites">
                                <i class="bi bi-heart-fill fs-5"></i>
                            </button>
                        </form>
                    <% } else { %>
                        <form action="/equipment/<%= foundEquipment._id %>/favorited-by/<%= user._id %>" method="POST" class="m-0">
                            <button class="btn btn-outline-danger rounded-circle p-2 lh-1 shadow-sm" type="submit" title="Add to Favorites">
                                <i class="bi bi-heart fs-5"></i>
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
            <div class="mb-4">
                <span class="badge bg-danger fs-5 me-2"><%= foundEquipment.dailyPrice %> BHD / day</span>
                <span class="badge bg-light text-dark border fs-6"><i class="bi bi-tag-fill me-1 text-danger"></i><%= foundEquipment.category %></span>
            </div>

            <p class="text-muted fs-5 mb-4" style="line-height: 1.8;">
                <%= foundEquipment.description %>
            </p>

            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="bg-light rounded-circle d-flex justify-content-center align-items-center me-3 border" style="width: 50px; height: 50px;">
                    <i class="bi bi-person-fill fs-3 text-muted"></i>
                </div>
                <div>
                    <p class="mb-0 text-muted small">Listed by</p>
                    <p class="mb-0 fw-bold fs-5"><%= foundEquipment.owner.username %></p>
                </div>
            </div>
            <% if (user._id === foundEquipment.owner._id.toString()) { %>
                <div class="owner-actions d-flex gap-3 mt-2">
                    <a href="/equipment/<%= foundEquipment._id %>/edit" class="btn btn-dark px-4 py-2 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Edit Equipment
                    </a>
                    <a href="/equipment/<%= foundEquipment._id %>/delete" class="btn btn-outline-danger px-4 py-2 fw-bold">
                        <i class="bi bi-trash me-2"></i>Delete
                    </a>
                </div>

            <% } else if (user.role === 'renter') { %>
                <div class="card border-0 shadow-sm rounded-4 mt-2 bg-light">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4"><i class="bi bi-calendar-check text-danger me-2"></i>Book this Equipment</h4>
                        <form action="/equipment/<%= foundEquipment._id %>/bookings" method="POST">
                            <div class="row g-3 mb-4">
                                <div class="col-sm-6">
                                    <label class="form-label text-muted small fw-bold">Start Date:</label>
                                    <input type="date" name="startDate" class="form-control form-control-lg border-0 shadow-sm" required>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label text-muted small fw-bold">End Date:</label>
                                    <input type="date" name="endDate" class="form-control form-control-lg border-0 shadow-sm" required>
                                </div>
                            </div>
                            <button class="btn btn-danger btn-lg w-100 fw-bold" type="submit">Book Now</button>
                        </form>
                    </div>
                </div>
            <% } %>

        </div>
    </div>

</main>

<%- include("../partials/footer.ejs") %>