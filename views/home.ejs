<%- include("./partials/nav.ejs") %>

    <main class="homepage">

        <section class="banner">
            <div class="overlay">
                <div class="intro">

                    <div class="welcome">
                        <% if (user) { %>
                            <p class="greeting">Welcome back, <%= user.username %><br /> Ready to shoot?</p>
                            <% } else { %>
                                <p class="greeting">Join the community to rent or list professional gear.</p>
                                <% } %>
                    </div>

                    <h1 class="title text-center">Elevate Your Vision with Pro Gear.</h1>
                    <p class="description">
                        Access the industry's most advanced cinematography equipment through our peer-to-peer
                        marketplace. Professional results without the capital overhead.
                    </p>

                    <div class="actions">
                        <a class="btn btn-danger" href="/equipment">Browse Gear</a>
                        <% if (!user || user.role==='owner' ) { %>
                            <a class="btn btn-light" href="/equipment/new">List Your Equipment</a>
                            <% } else if (user && user.role==='renter' ) { %>
                                <a class="btn btn-light" href="/bookings/my-bookings">My Bookings</a>
                                <% } %>
                    </div>
                </div>
            </div>
        </section>
        <section class="workflow container mt-5 mb-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Master Your Workflow</h2>
                <p class="text-muted">Seamless transactions designed for the technical demands of professional production.</p>
            </div>        
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body p-4 p-lg-5">
                            <h3 class="card-title text-danger mb-4">
                                <i class="bi bi-camera-reels me-2"></i>For Renters
                            </h3>
                            <ol class="text-muted ps-3" style="line-height: 1.8;">
                                <li class="mb-3"><strong>Discover & Request:</strong> Browse curated listings and request gear based on your shoot schedule.</li>
                                <li class="mb-3"><strong>Secure Pick-up:</strong> Coordinate with verified owners for hand over or professional delivery.</li>
                                <li><strong>Create & Return:</strong> Focus on your vision. Return the gear once the production wraps.</li>
                            </ol>
                        </div>
                    </div>
                </div>        
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body p-4 p-lg-5">
                            <h3 class="card-title text-danger mb-4">
                                <i class="bi bi-shop me-2"></i>For Owners
                            </h3>
                            <ol class="text-muted ps-3" style="line-height: 1.8;">
                                <li class="mb-3"><strong>List Your Inventory:</strong> Create high spec listings for your equipment with detailed tech data.</li>
                                <li class="mb-3"><strong>Vetted Approvals:</strong> Review rental requests from verified creators in the community.</li>
                                <li><strong>Earn & Insure:</strong> Monetize your idle gear with total peace of mind through our coverage.</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include("./partials/footer.ejs") %>