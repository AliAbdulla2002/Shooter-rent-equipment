<%- include("partials/nav.ejs") %>

<main class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="py-5">
                
                <i class="bi bi-exclamation-triangle-fill text-danger display-1 mb-4 d-block"></i>
                
                <h1 class="fw-bold mb-4">Oops! Something went wrong.</h1>
                
                <div class="alert alert-danger fs-5 border-0 shadow-sm rounded-4 mb-5" role="alert">
                    <%= msg %>
                </div>
                
                <a href="/" class="btn btn-dark btn-lg px-5 fw-bold">
                    <i class="bi bi-house-door-fill me-2"></i>Go back to Home
                </a>
                
            </div>
        </div>
    </div>
</main>

<%- include("partials/footer.ejs") %>